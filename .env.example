# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_numeric_user_id_here

# Optional
DB_PATH=/data/accounts.db
DATA_DIR=/data
PROFILE_DIR=/data/profiles
BROWSER_HEADLESS=false
BROWSER_TIMEZONE=Asia/Tokyo
BROWSER_LOCALE=ja-JP
BROWSER_GEOIP=false
RUN_ON_START=false
RENEWAL_THRESHOLD_DAYS=1
CLOAKBROWSER_CACHE_DIR=/data/.cloakbrowser
# Recommended on Zeabur/datacenter hosting for Cloudflare Turnstile.
# CLOAKBROWSER_PROXY=http://user:pass@residential-proxy-host:port

# Optional: use CloakBrowser Pro binary if you have a key
# CLOAKBROWSER_LICENSE_KEY=cb_xxxxxxxx
